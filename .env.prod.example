# ── 앱 설정 ──────────────────────────────
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com

# ── 데이터베이스 ──────────────────────────
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=homepage_builder
DB_USERNAME=homepage_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# MySQL root 비밀번호 (docker-compose.prod.yml 에서 사용)
MYSQL_ROOT_PASSWORD=CHANGE_THIS_ROOT_PASSWORD

# ── JWT ───────────────────────────────────
# openssl rand -base64 48 으로 생성
JWT_SECRET=CHANGE_THIS_TO_RANDOM_48CHAR_STRING
JWT_EXPIRY=86400

# ── CORS ──────────────────────────────────
ALLOWED_ORIGINS=https://your-domain.com

# ── OAuth (선택) ───────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/oauth/google/callback

KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://your-domain.com/api/auth/oauth/kakao/callback

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=https://your-domain.com/api/auth/oauth/naver/callback
