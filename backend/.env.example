# 앱 설정
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:8000

# 데이터베이스
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=homepage_builder
DB_USERNAME=root
DB_PASSWORD=secret

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRY=86400

# 이메일 (PHPMailer SMTP) — 댓글 알림 발송
# 설정하지 않으면 이메일 알림 비활성화 (앱 내 알림만 동작)
SITE_URL=http://localhost:3000
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=홈페이지 알림

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/oauth/google/callback

# OAuth - Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:8000/api/auth/oauth/kakao/callback

# OAuth - Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=http://localhost:8000/api/auth/oauth/naver/callback
