# 앱 설정
APP_ENV=production
APP_DEBUG=false
APP_URL=https://your-domain.com

# 데이터베이스
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=homepage_builder
DB_USERNAME=your_db_user
DB_PASSWORD=your_db_password

# JWT
JWT_SECRET=CHANGE-THIS-TO-A-SECURE-RANDOM-STRING
JWT_EXPIRY=86400

# 이메일 (PHPMailer SMTP)
SITE_URL=https://your-domain.com
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_ENCRYPTION=tls
MAIL_FROM=your-email@gmail.com
MAIL_FROM_NAME=홈페이지 알림

# OAuth - Google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/auth/oauth/google/callback

# OAuth - Kakao
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=https://your-domain.com/api/auth/oauth/kakao/callback

# OAuth - Naver
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_REDIRECT_URI=https://your-domain.com/api/auth/oauth/naver/callback

# Sentry 에러 추적 (선택사항 -- DSN 없으면 비활성화)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_TRACES_RATE=0.1
APP_VERSION=1.0.0
